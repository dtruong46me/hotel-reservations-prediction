# =============================================================================
# .gitignore — Hotel Reservations Prediction
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- Environment / secrets ---
.env
*.env
secrets/
**/service-account*.json
**/key*.json

# --- Generated artifacts (runtime outputs) ---
artifacts/
mlruns/
mlartifacts/

# --- Logs ---
logs/

# --- Data (large files, managed separately) ---
data/
dataset/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_meta

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Test & coverage ---
.pytest_cache/
.coverage
htmlcov/